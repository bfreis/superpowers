#!/usr/bin/env bash
# Generate a review package: commit list, stat summary, and the net
# diff with extended context, written to a file the reviewer reads in one
# call. Using the recorded per-task BASE (not HEAD~1) keeps multi-commit
# tasks intact.
#
# Usage: review-package BASE HEAD [OUTFILE]
# Default OUTFILE: <repo-root>/.superpowers/sdd/review-<base7>..<head7>.diff
# (named per range, so a re-review after fixes gets a distinct fresh file).
set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "usage: review-package BASE HEAD [OUTFILE]" >&2
  exit 2
fi

base=$1
head=$2

# Detect VCS. jj root succeeds in any jj repo (colocated or standalone);
# a colocated repo prefers jj. Fall back to git otherwise.
if jj root >/dev/null 2>&1; then
  VCS=jj
else
  VCS=git
fi

short_rev() {
  if [ "$VCS" = jj ]; then
    jj log -r "$1" --no-graph --no-pager -T 'change_id.short()' 2>/dev/null | head -1
  else
    git rev-parse --short "$1"
  fi
}

verify_rev() {
  if [ "$VCS" = jj ]; then
    jj log -r "$1" --no-graph --no-pager -T '"x"' >/dev/null 2>&1
  else
    git rev-parse --verify --quiet "$1" >/dev/null 2>&1
  fi
}

verify_rev "$base" || { echo "bad BASE: $base" >&2; exit 2; }
verify_rev "$head" || { echo "bad HEAD: $head" >&2; exit 2; }

if [ $# -eq 3 ]; then
  out=$3
else
  dir=$("$(cd "$(dirname "$0")" && pwd)/sdd-workspace")
  out="$dir/review-$(short_rev "$base")..$(short_rev "$head").diff"
fi

if [ "$VCS" = jj ]; then
  {
    echo "# Review package: ${base}..${head}"
    echo
    echo "## Commits"
    jj log -r "${base}..${head}" --no-graph --no-pager \
      -T 'change_id.short() ++ " " ++ description.first_line() ++ "\n"'
    echo
    echo "## Files changed"
    jj diff --stat --from "${base}" --to "${head}"
    echo
    echo "## Diff"
    jj diff --context 10 --from "${base}" --to "${head}"
  } > "$out"
  commits=$(jj log -r "${base}..${head}" --no-graph --no-pager -T '"x\n"' | wc -l | tr -d ' ')
else
  {
    echo "# Review package: ${base}..${head}"
    echo
    echo "## Commits"
    git log --oneline "${base}..${head}"
    echo
    echo "## Files changed"
    git diff --stat "${base}..${head}"
    echo
    echo "## Diff"
    git diff -U10 "${base}..${head}"
  } > "$out"
  commits=$(git rev-list --count "${base}..${head}")
fi

echo "wrote ${out}: ${commits} commit(s), $(wc -c < "$out" | tr -d ' ') bytes"
